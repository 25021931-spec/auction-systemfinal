<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.AdminController"
            style="-fx-background-color: #0f1923;"
            prefWidth="860" prefHeight="580">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color: #1a2d3d; -fx-padding: 14 20 14 20;">
            <Text text="AUCTION SYSTEM"
                  style="-fx-font-size: 18; -fx-fill: #e8b84b; -fx-font-weight: bold;"/>
            <Text text="Admin Dashboard" style="-fx-font-size: 14; -fx-fill: #e85050;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Tai lai" onAction="#loadUsers"
                    style="-fx-background-color: #2d4a63; -fx-text-fill: #c8d8e8;
                           -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 14 6 14;"/>
            <Button text="Can user" onAction="#handleBanUser"
                    style="-fx-background-color: #7a2d2d; -fx-text-fill: white;
                           -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 14 6 14;"/>
            <Button text="Dang xuat" onAction="#handleLogout"
                    style="-fx-background-color: #3d3d3d; -fx-text-fill: white;
                           -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 14 6 14;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="12" style="-fx-padding: 20;">
            <Label text="QUAN LY NGUOI DUNG"
                   style="-fx-text-fill: #c8d8e8; -fx-font-size: 14; -fx-font-weight: bold;"/>
            <TableView fx:id="usersTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #1a2d3d; -fx-border-color: #2d4a63;">
                <columns>
                    <TableColumn fx:id="idCol" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="usernameCol" text="Ten dang nhap" prefWidth="180"/>
                    <TableColumn fx:id="emailCol" text="Email" prefWidth="220"/>
                    <TableColumn fx:id="roleCol" text="Vai tro" prefWidth="100"/>
                    <TableColumn fx:id="activeCol" text="Hoat dong" prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="Khong co nguoi dung" style="-fx-text-fill: #4a6a83;"/>
                </placeholder>
            </TableView>
            <Label fx:id="statusLabel" text=""
                   style="-fx-text-fill: #7a9ab8; -fx-font-size: 12;"/>
        </VBox>
    </center>
</BorderPane>
