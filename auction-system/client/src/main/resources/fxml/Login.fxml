<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.controller.LoginController"
      alignment="CENTER" spacing="0"
      prefWidth="460" prefHeight="600"
      style="-fx-background-color: #0f1923;">

    <VBox alignment="CENTER" spacing="6"
          style="-fx-background-color: #1a2d3d; -fx-padding: 28 0 28 0;">
        <Text text="AUCTION SYSTEM"
              style="-fx-font-size: 26; -fx-fill: #e8b84b; -fx-font-weight: bold;"/>
        <Text text="Online Bidding Platform"
              style="-fx-font-size: 13; -fx-fill: #7a9ab8;"/>
    </VBox>

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"
             style="-fx-background-color: #0f1923;">

        <!-- TAB DANG NHAP -->
        <Tab text="Dang Nhap">
            <VBox alignment="CENTER" spacing="14"
                  style="-fx-background-color: #0f1923; -fx-padding: 36 60 36 60;">
                <Label text="Chao mung tro lai"
                       style="-fx-text-fill: #c8d8e8; -fx-font-size: 15;"/>
                <VBox spacing="5">
                    <Label text="Ten dang nhap" style="-fx-text-fill: #7a9ab8; -fx-font-size: 12;"/>
                    <TextField fx:id="loginUsernameField" promptText="Nhap ten dang nhap"
                               style="-fx-background-color: #1a2d3d; -fx-text-fill: white;
                                      -fx-border-color: #2d4a63; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 10; -fx-font-size: 13;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Mat khau" style="-fx-text-fill: #7a9ab8; -fx-font-size: 12;"/>
                    <PasswordField fx:id="loginPasswordField" promptText="Nhap mat khau"
                                   style="-fx-background-color: #1a2d3d; -fx-text-fill: white;
                                          -fx-border-color: #2d4a63; -fx-border-radius: 6;
                                          -fx-background-radius: 6; -fx-padding: 10; -fx-font-size: 13;"/>
                </VBox>
                <Button text="DANG NHAP" onAction="#handleLogin" maxWidth="Infinity"
                        style="-fx-background-color: #e8b84b; -fx-text-fill: #0f1923;
                               -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 12;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Label fx:id="messageLabel" text="" wrapText="true" maxWidth="320"
                       style="-fx-font-size: 12;"/>
            </VBox>
        </Tab>

        <!-- TAB DANG KY -->
        <Tab text="Dang Ky">
            <VBox alignment="CENTER" spacing="12"
                  style="-fx-background-color: #0f1923; -fx-padding: 28 60 28 60;">
                <Label text="Tao tai khoan moi"
                       style="-fx-text-fill: #c8d8e8; -fx-font-size: 15;"/>
                <VBox spacing="5">
                    <Label text="Ten dang nhap" style="-fx-text-fill: #7a9ab8; -fx-font-size: 12;"/>
                    <TextField fx:id="regUsernameField" promptText="Toi thieu 3 ky tu"
                               style="-fx-background-color: #1a2d3d; -fx-text-fill: white;
                                      -fx-border-color: #2d4a63; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 10;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Mat khau" style="-fx-text-fill: #7a9ab8; -fx-font-size: 12;"/>
                    <PasswordField fx:id="regPasswordField" promptText="Toi thieu 6 ky tu"
                                   style="-fx-background-color: #1a2d3d; -fx-text-fill: white;
                                          -fx-border-color: #2d4a63; -fx-border-radius: 6;
                                          -fx-background-radius: 6; -fx-padding: 10;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Email" style="-fx-text-fill: #7a9ab8; -fx-font-size: 12;"/>
                    <TextField fx:id="regEmailField" promptText="example@email.com"
                               style="-fx-background-color: #1a2d3d; -fx-text-fill: white;
                                      -fx-border-color: #2d4a63; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 10;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Vai tro" style="-fx-text-fill: #7a9ab8; -fx-font-size: 12;"/>
                    <ComboBox fx:id="roleCombo" maxWidth="Infinity"
                              style="-fx-background-color: #1a2d3d;
                                     -fx-border-color: #2d4a63; -fx-border-radius: 6;
                                     -fx-background-radius: 6;"/>
                </VBox>
                <Button text="DANG KY" onAction="#handleRegister" maxWidth="Infinity"
                        style="-fx-background-color: #2d7a4f; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 12;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Label fx:id="messageLabel" text="" wrapText="true" maxWidth="320"
                       style="-fx-font-size: 12;"/>
            </VBox>
        </Tab>
    </TabPane>

    <Label text="Admin mac dinh: admin / admin123"
           style="-fx-text-fill: #3d5a73; -fx-font-size: 11; -fx-padding: 8 0 8 0;"/>
</VBox>
