<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.AuctionListController"
            style="-fx-background-color: #0f1923;"
            prefWidth="900" prefHeight="620">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #1a2d3d; -fx-padding: 14 20 14 20;">
            <Text text="AUCTION SYSTEM"
                  style="-fx-font-size: 18; -fx-fill: #e8b84b; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel" style="-fx-text-fill: #7a9ab8; -fx-font-size: 13;"/>
            <Button text="Tai lai" onAction="#loadAuctions"
                    style="-fx-background-color: #2d4a63; -fx-text-fill: #c8d8e8;
                           -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 14 6 14;"/>
            <Button text="Dang xuat" onAction="#handleLogout"
                    style="-fx-background-color: #7a2d2d; -fx-text-fill: white;
                           -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 14 6 14;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="12" style="-fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Text text="Phien Dau Gia"
                      style="-fx-font-size: 16; -fx-fill: #c8d8e8; -fx-font-weight: bold;"/>
                <Text text="(Double-click de tham gia)"
                      style="-fx-font-size: 12; -fx-fill: #4a6a83;"/>
            </HBox>
            <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #1a2d3d; -fx-border-color: #2d4a63;">
                <columns>
                    <TableColumn fx:id="idCol" text="ID" prefWidth="55"/>
                    <TableColumn fx:id="nameCol" text="San pham" prefWidth="220"/>
                    <TableColumn fx:id="categoryCol" text="Danh muc" prefWidth="110"/>
                    <TableColumn fx:id="priceCol" text="Gia hien tai" prefWidth="120"/>
                    <TableColumn fx:id="leaderCol" text="Nguoi dan dau" prefWidth="130"/>
                    <TableColumn fx:id="endTimeCol" text="Ket thuc" prefWidth="160"/>
                    <TableColumn fx:id="statusCol" text="Trang thai" prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="Chua co phien dau gia nao"
                           style="-fx-text-fill: #4a6a83;"/>
                </placeholder>
            </TableView>
            <Label fx:id="statusBar" text=""
                   style="-fx-text-fill: #4a6a83; -fx-font-size: 12;"/>
        </VBox>
    </center>
</BorderPane>
