<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.BiddingController"
            style="-fx-background-color: #0f1923;"
            prefWidth="1050" prefHeight="700">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color: #1a2d3d; -fx-padding: 12 20 12 20;">
            <Button text="Quay lai" onAction="#handleBack"
                    style="-fx-background-color: #2d4a63; -fx-text-fill: #c8d8e8;
                           -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 14 6 14;"/>
            <Label fx:id="itemNameLabel" text="San pham"
                   style="-fx-font-size: 18; -fx-text-fill: #e8b84b; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER">
                <Label text="CON LAI" style="-fx-text-fill: #7a9ab8; -fx-font-size: 10;"/>
                <Label fx:id="countdownLabel" text="--:--:--"
                       style="-fx-font-size: 22; -fx-text-fill: #e85050; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>
    </top>
    <center>
        <HBox spacing="0">
            <VBox spacing="14" minWidth="300" maxWidth="320"
                  style="-fx-background-color: #131f2b; -fx-padding: 20;
                         -fx-border-color: #1e3347; -fx-border-width: 0 1 0 0;">
                <VBox style="-fx-background-color: #1a2d3d; -fx-background-radius: 10;
                             -fx-padding: 16; -fx-spacing: 4;" alignment="CENTER">
                    <Label text="GIA HIEN TAI" style="-fx-text-fill: #7a9ab8; -fx-font-size: 11;"/>
                    <Label fx:id="currentPriceLabel" text="0 VND"
                           style="-fx-font-size: 24; -fx-text-fill: #e8b84b; -fx-font-weight: bold;"/>
                    <Label text="Nguoi dan dau:" style="-fx-text-fill: #7a9ab8; -fx-font-size: 11;"/>
                    <Label fx:id="leaderLabel" text="---"
                           style="-fx-font-size: 14; -fx-text-fill: #4dc47a; -fx-font-weight: bold;"/>
                </VBox>
                <HBox spacing="8">
                    <Label text="Ket thuc:" style="-fx-text-fill: #7a9ab8; -fx-font-size: 12;"/>
                    <Label fx:id="endTimeLabel" text=""
                           style="-fx-text-fill: #c8d8e8; -fx-font-size: 12;"/>
                </HBox>
                <HBox spacing="8">
                    <Label text="Trang thai:" style="-fx-text-fill: #7a9ab8; -fx-font-size: 12;"/>
                    <Label fx:id="statusLabel" text=""
                           style="-fx-text-fill: #4dc47a; -fx-font-size: 12; -fx-font-weight: bold;"/>
                </HBox>
                <Separator/>
                <Label text="DAT GIA THU CONG"
                       style="-fx-text-fill: #c8d8e8; -fx-font-size: 13; -fx-font-weight: bold;"/>
                <TextField fx:id="bidAmountField" promptText="Nhap so tien..."
                           style="-fx-background-color: #1a2d3d; -fx-text-fill: white;
                                  -fx-border-color: #2d4a63; -fx-border-radius: 6;
                                  -fx-background-radius: 6; -fx-padding: 9;"/>
                <Button fx:id="placeBidBtn" text="DAT GIA NGAY" onAction="#handlePlaceBid"
                        maxWidth="Infinity"
                        style="-fx-background-color: #e8b84b; -fx-text-fill: #0f1923;
                               -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 11;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Separator/>
                <Label text="DAU GIA TU DONG"
                       style="-fx-text-fill: #c8d8e8; -fx-font-size: 13; -fx-font-weight: bold;"/>
                <HBox spacing="8">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Gia toi da" style="-fx-text-fill: #7a9ab8; -fx-font-size: 11;"/>
                        <TextField fx:id="maxBidField" promptText="Max bid..."
                                   style="-fx-background-color: #1a2d3d; -fx-text-fill: white;
                                          -fx-border-color: #2d4a63; -fx-border-radius: 6;
                                          -fx-background-radius: 6; -fx-padding: 8;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Buoc tang" style="-fx-text-fill: #7a9ab8; -fx-font-size: 11;"/>
                        <TextField fx:id="incrementField" promptText="Increment..."
                                   style="-fx-background-color: #1a2d3d; -fx-text-fill: white;
                                          -fx-border-color: #2d4a63; -fx-border-radius: 6;
                                          -fx-background-radius: 6; -fx-padding: 8;"/>
                    </VBox>
                </HBox>
                <Button fx:id="autoBidBtn" text="BAT AUTO-BID" onAction="#handleAutoBid"
                        maxWidth="Infinity"
                        style="-fx-background-color: #2d5a8e; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13; -fx-padding: 10;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
            </VBox>
            <VBox spacing="12" HBox.hgrow="ALWAYS" style="-fx-padding: 16;">
                <LineChart fx:id="priceChart" prefHeight="260" VBox.vgrow="NEVER"
                           style="-fx-background-color: #1a2d3d; -fx-background-radius: 8;">
                    <xAxis>
                        <CategoryAxis label="Thoi gian"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Gia (VND)"/>
                    </yAxis>
                </LineChart>
                <Label text="LICH SU DAT GIA"
                       style="-fx-text-fill: #7a9ab8; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <TableView fx:id="bidHistoryTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #1a2d3d; -fx-border-color: #2d4a63;">
                    <columns>
                        <TableColumn fx:id="bidderCol" text="Nguoi dat" prefWidth="160"/>
                        <TableColumn fx:id="amountCol" text="So tien" prefWidth="130"/>
                        <TableColumn fx:id="timeCol" text="Thoi gian" prefWidth="100"/>
                        <TableColumn fx:id="autoCol" text="Loai" prefWidth="80"/>
                    </columns>
                    <placeholder>
                        <Label text="Chua co luot dat gia" style="-fx-text-fill: #4a6a83;"/>
                    </placeholder>
                </TableView>
            </VBox>
        </HBox>
    </center>
</BorderPane>
